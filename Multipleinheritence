#include <iostream>
using namespace std;
class Base1
{
public:
    int base1int;
    int set_base1int(int a)
    {
        base1int = a;
    }
};
class Base2
{
public:
    int base2int;

    int set_base2int(int a)
    {
        base2int = a;
    }
};
class Base3
{
public:
    int base3int;

    int set_base3int(int a)
    {
        base3int = a;
    }
};
class Derived : public Base1, public Base2, public Base3
{
public:
    int show()
    {
        cout << "The value of base1 is :" << base1int << endl;
        cout << "The value of base2 is :" << base2int << endl;
        cout << "The value of base3 is :" << base3int << endl;
        cout << "The sum of these values is :" << base1int + base2int + base3int << endl;
    }
};
/*
Syntax for the multiple inheritence:-
class DerivedC : visibility-Mode base1, visibility-Mode2{
Class body of class "DerivedC"

};
*/
int main()
{
    Derived harry;
    harry.set_base1int(25);
    harry.set_base2int(205);
    harry.set_base3int(45);
    harry.show();
    return 0;
}